#include <stdio.h>

void leMatriz(int m1[4][4]) {
    int i, j;

    for (i = 0; i < 4; i++) {
        for (j = 0; j < 4; j++) {
            printf("Digite um numero para sua matriz: \n");
            scanf("%d", &m1[i][j]);
        }
    }
}

void imprimeDiagonal(int m2[4][4]) {
    int i, j;

    for (i = 0; i < 4; i++) {
        for (j = 0; j < 4; j++) {
            if (i == j) {
                printf("%d", m2[i][j]);
            } else {
                printf(" ");
            }
        }
        printf("\n");
    }
}

void traco(int m3[4][4]) {
    int i, j;
    int soma = 0;

    for (i = 0; i < 4; i++) {
        for (j = 0; j < 4; j++) {
            if (i == j) {
                soma = soma + m3[i][j];
            }
        }
    }

    printf("A soma dos elementos das diagonais principais sao: %d", soma);
}

void somaAcimaDiagonal(int m4[4][4]){
    int i = 0, j = 0, aux = 0;
    int soma = 0;

    for (i = 0; i < 4; i++) {
        aux += 1;
        for (j = aux; j < 4; j++) {
        soma += m4[i][j];
        }
    }
    printf("A soma dos elementos acima da diagonal sâo: %d\n", soma);
}

int main() {
    int m[4][4];

    leMatriz(m);
    imprimeDiagonal(m);
    traco(m);
    somaAcimaDiagonal(m);

    return 0;
}

